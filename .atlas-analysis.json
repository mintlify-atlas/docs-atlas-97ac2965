  "keyFeatures": [
    "Offline Quran reading with full page caching",
    "Gesture-based swipe navigation between pages",
    "Multiple Quran Riwayas (Hafs and Warsh)",
    "Dynamic Tafseer popups with 10+ classical commentaries",
    "Advanced search with fuzzy, root, and lemma search",
    "Daily reading tracker with progress goals",
    "Cross-platform support (Android, iOS, Web, macOS)",
    "PWA support with service worker caching",
    "Android home screen widgets",
    "Dark mode and customizable reading experience"
  ],
  "publicApiSurface": [
    "useQuranMetadata() - Access Quran metadata (surahs, ayahs, pages)",
    "useCurrentPage() - Get and set current Mushaf page",
    "useTafseerContent() - Load Tafseer data for verses",
    "useQuranSearch() - Search Quran with various modes",
    "useImagePreloader() - Preload Mushaf page images",
    "currentSavedPage atom - Persistent page position",
    "mushafRiwaya atom - Selected Quran recitation (Hafs/Warsh)",
    "dailyTrackerGoal atom - Daily reading goal",
    "tafseerTab atom - Selected Tafseer source",
    "MushafPage component - Main Quran page viewer",
    "TafseerPopup component - Bottom sheet Tafseer display",
    "PageNavigator component - Surah/Ayah/Juz navigation",
    "TopMenu component - Reading interface controls"
  ]
}
